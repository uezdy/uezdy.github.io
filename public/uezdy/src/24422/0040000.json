        "from": "Мила Шел",
        "from_id": "user5152221638",
        "reply_to_message_id": 24422,
        "text": [
            {
                "type": "bold",
                "text": "ГАКО"
            },
            " ( ",
            {
                "type": "bold",
                "text": "г.Курган"
            },
            ")\nВыписала фамилии, которые попались в метрич.кн. за 1914-1917 г\n\nГродненская губерния\n",
            {
                "type": "bold",
                "text": "Слонимский уезд"
            },
            "\nБытинская волость\nд.Козино\n",
            {
                "type": "bold",
                "text": "Капралов"
            },
            " Степан Авкатьев(ич)\n",
            {
                "type": "bold",
                "text": "Холин"
            },
            "  Александр Григорьев(ич)\n",
            {
                "type": "bold",
                "text": "Хоменя"
            },
            "(Хомена?)Василий Николаев(ич)\n\nКобренского уезда\n ",
            {
                "type": "bold",
                "text": "Сихновско"
            },
            "й вол.\nд.Грицевки\n",
            {
                "type": "bold",
                "text": "Волосюк"
            },
            " Александр Прокопиев\n\nЖировицкой вол.\n",
            {
                "type": "bold",
                "text": "Горох"
            },
            " Даниил Антонов\n\nГродненской губ.\n",
            {
                "type": "bold",
                "text": "Генаш"
            },
            " А.Ф.\n",
            {
                "type": "bold",
                "text": "Грузинский"
            },
            " И.К.\n",
            {
                "type": "bold",
                "text": "Бахматов"
            },
            " М.Ф.\n",
            {
                "type": "bold",
                "text": "Сахарков"
            },
            " С.П.\n",
            {
                "type": "bold",
                "text": "Колань"
            },
            "(?) А.К.\n",
            {
                "type": "bold",
                "text": "Тарасюк"
            },
            " П.Г.\n",
            {
                "type": "bold",
                "text": "Приходько"
            },
            " В.И.\n",
            {
                "type": "bold",
                "text": "Туляй"
            },
            "(?) Я.П.\n",
            {
                "type": "bold",
                "text": "Долчелюк"
            },
            "(Долголюк) Д.И.\n",
            {
                "type": "bold",
                "text": "Хомена"
            },
            " А.Н.\n",
            {
                "type": "bold",
                "text": "Котов"
            },
            " С.Т.\n",
            {
                "type": "bold",
                "text": "Зарецких"
            },
            " А.С\n\n."
        ],
