                "href": "https://www.radzima.net/ru/miejsce/kokotov.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Колбов, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/kolbov.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Коровчина Слобода, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/korovchina_sloboda.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Мордасовы Концы, посёлок",
                "href": "https://www.radzima.net/ru/miejsce/mordasovy_kontsy.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Немки, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/nemki.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Осовины, околица",
                "href": "https://www.radzima.net/ru/miejsce/osoviny.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Осовины, хутор.",
                "href": "https://www.radzima.net/ru/miejsce/osoviny_1.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Острая Грива, урочище",
                "href": "https://www.radzima.net/ru/miejsce/ostraya_griva.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Перунов, околица..",
                "href": "https://www.radzima.net/ru/miejsce/perunov.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Перунов, хутор..",
                "href": "https://www.radzima.net/ru/miejsce/perunov_1.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Песьи Гряды, посёлок",
                "href": "https://www.radzima.net/ru/miejsce/pesji_gryady.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Пильники, хутор.",
                "href": "https://www.radzima.net/ru/miejsce/pilniki.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Подмельнище, хутор",
                "href": "https://www.radzima.net/ru/miejsce/podmelnishche.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Проточное, слобода..",
                "href": "https://www.radzima.net/ru/miejsce/protochnoe.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Ржавка, усадьба",
                "href": "https://www.radzima.net/ru/miejsce/rzhavka_1.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Романятская Гута, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/romanyatskaya_guta.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Слуки, усадьба",
                "href": "https://www.radzima.net/ru/miejsce/sluki.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Смышель, усадьба",
                "href": "https://www.radzima.net/ru/miejsce/smyshel.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Стайки, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/stayki_2.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Сукач, посёлок.",
                "href": "https://www.radzima.net/ru/miejsce/sukach.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Тартак, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/tartak_8.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Точище, хутор",
                "href": "https://www.radzima.net/ru/miejsce/tochishche.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Фабияновка, хутор",
                "href": "https://www.radzima.net/ru/miejsce/fabiyanovka.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Хватовка, посёлок.",
                "href": "https://www.radzima.net/ru/miejsce/khvatovka.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Хонов, посёлок..",
                "href": "https://www.radzima.net/ru/miejsce/khonov_2.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Чечевичи, деревня...",
                "href": "https://www.radzima.net/ru/miejsce/chechevichi.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Чигиринка, имение..",
                "href": "https://www.radzima.net/ru/miejsce/chigirinka.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Чигиринка, село....",
                "href": "https://www.radzima.net/ru/miejsce/chigirinka_1.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Шалаевка, деревня..",
                "href": "https://www.radzima.net/ru/miejsce/shalaevka.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Шмаки, деревня...",
                "href": "https://www.radzima.net/ru/miejsce/shmaki.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Шмаки, хутор.",
                "href": "https://www.radzima.net/ru/miejsce/shmaki_1.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Юзин, хутор.",
                "href": "https://www.radzima.net/ru/miejsce/yuzin.html"
            },
            {
                "type": "plain",
                "text": "\n"
            },
            {
                "type": "text_link",
                "text": "Ямное, посёлок",
                "href": "https://www.radzima.net/ru/miejsce/yamnoe_1.html"
            },
            {
                "type": "plain",
                "text": ""
            }
